{
  "name": "kitodo",
  "version": "0.6.4",
  "description": "Launcher de tareas local con Electron, SvelteKit y Rust",
  "author": "kitotsu",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite dev",
    "build": "pnpm run build:web",
    "build:web": "svelte-kit sync && vite build",
    "build:server": "cargo build --manifest-path src-tauri/Cargo.toml --release --bin kitodo-server",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "electron:dev": "concurrently -k \"pnpm dev\" \"cargo build --manifest-path src-tauri/Cargo.toml --bin kitodo-server && wait-on tcp:5173 && electron .\"",
    "electron:start": "cargo build --manifest-path src-tauri/Cargo.toml --bin kitodo-server && electron .",
    "appimage:build": "bash ./scripts/build-appimage.sh"
  },
  "dependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "concurrently": "^9.1.2",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.12",
    "svelte-check": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "io.github.KitotsuMolina.KitoDo",
    "productName": "KitoDo",
    "artifactName": "KitoDo_${arch}.${ext}",
    "asar": true,
    "directories": {
      "output": "dist-electron",
      "buildResources": "assets"
    },
    "files": [
      "build/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src-tauri/target/release/kitodo-server",
        "to": "bin/kitodo-server"
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office",
      "icon": "assets/kitodo-icon.png",
      "executableName": "kitodo"
    }
  }
}
